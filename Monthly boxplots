# -----------------------
# 10) ETCCDI-like indices + ranking
# -----------------------
WET_DAY_MM = 1.0
R10 = 10.0
R20 = 20.0

def longest_run(bool_arr):
    max_run = run = 0
    for v in bool_arr:
        if v:
            run += 1
            max_run = max(max_run, run)
        else:
            run = 0
    return max_run

def annual_indices(series: pd.Series, p95_thr: float, p99_thr: float) -> pd.DataFrame:
    df = series.to_frame("p").copy()
    df["year"] = df.index.year
    df["roll5"] = df["p"].rolling(5).sum()

    out = []
    for y, g in df.groupby("year"):
        px = g["p"].values
        rx1 = float(np.nanmax(px)) if len(px) else np.nan
        rx5 = float(np.nanmax(g["roll5"].values)) if len(g) else np.nan
        r10 = int(np.sum(px >= R10))
        r20 = int(np.sum(px >= R20))
        cdd = int(longest_run(px < WET_DAY_MM))
        cwd = int(longest_run(px >= WET_DAY_MM))
        r95p = float(np.nansum(px[px > p95_thr]))
        r99p = float(np.nansum(px[px > p99_thr]))
        prcptot = float(np.nansum(px[px >= WET_DAY_MM]))
        sdii = float(prcptot / max(np.sum(px >= WET_DAY_MM), 1))
        out.append([y, rx1, rx5, r10, r20, cdd, cwd, r95p, r99p, prcptot, sdii])

    cols = ["year","Rx1day","Rx5day","R10mm","R20mm","CDD","CWD","R95p","R99p","PRCPTOT","SDII"]
    return pd.DataFrame(out, columns=cols).set_index("year")

def rolling_rank(series: pd.Series, window_days: int, event_end: str):
    roll = series.rolling(window_days).sum().dropna()
    e_end = pd.to_datetime(event_end)
    if e_end not in roll.index:
        return {"window": window_days, "event_value": np.nan, "rank": np.nan, "n": int(len(roll)),
                "percentile": np.nan, "emp_return_period_yr": np.nan}

    ev = float(roll.loc[e_end])
    sorted_vals = np.sort(roll.values)[::-1]
    rank = int(np.searchsorted(-sorted_vals, -ev) + 1)
    n = int(len(sorted_vals))
    pct = float(stats.percentileofscore(roll.values, ev, kind="weak"))
    rp_years = float(((n + 1) / rank) / 365.25)
    return {"window": window_days, "event_value": ev, "rank": rank, "n": n,
            "percentile": pct, "emp_return_period_yr": rp_years}

def classify_event(ranks_df: pd.DataFrame) -> str:
    best = ranks_df.dropna(subset=["percentile","rank"]).copy()
    if best.empty:
        return "UNCLASSIFIED (event not covered in extracted series)"
    best = best.sort_values(["percentile","rank"], ascending=[False, True]).iloc[0]
    pct, rk = best["percentile"], best["rank"]
    if (pct >= 99.5) or (rk <= 5):
        return "EXTREME / EXCEPTIONAL (near-unprecedented)"
    if (pct >= 99.0) or (rk <= 20):
        return "VERY RARE (upper tail)"
    if (pct >= 97.5) or (rk <= 50):
        return "RARE (statistically unusual)"
    return "NOT RARE (precipitation-only criteria)"

def ensure_indices_and_ranking(p: pd.Series):
    if os.path.exists(CSV_INDICES) and os.path.getsize(CSV_INDICES) > 0 and \
       os.path.exists(CSV_RANKS) and os.path.getsize(CSV_RANKS) > 0:
        print("✅ Cache hit: Using existing indices/ranking CSVs.")
        ann = pd.read_csv(CSV_INDICES, index_col=0)
        ranks = pd.read_csv(CSV_RANKS)
        return ann, ranks

    baseline = p.loc[BASELINE_START:BASELINE_END]
    p95_base = np.nanpercentile(baseline.values, 95)
    p99_base = np.nanpercentile(baseline.values, 99)

    ann = annual_indices(p, p95_base, p99_base)
    ranks = pd.DataFrame([
        rolling_rank(p, 1, EVENT_END),
        rolling_rank(p, 2, EVENT_END),
        rolling_rank(p, 3, EVENT_END),
        rolling_rank(p, 5, EVENT_END),
        rolling_rank(p, 7, EVENT_END),
    ])

    ann.to_csv(CSV_INDICES)
    ranks.to_csv(CSV_RANKS, index=False)

    print("✅ Indices saved:", CSV_INDICES)
    print("✅ Ranking saved:", CSV_RANKS)
    return ann, ranks

