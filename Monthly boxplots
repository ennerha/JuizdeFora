def save_summary_table_figure(p: pd.Series, ann: pd.DataFrame, ranks: pd.DataFrame, spatial_df: pd.DataFrame, out_path: str, dpi: int = 500):
    fig, ax = plt.subplots(figsize=(14, 11))
    ax.axis('tight')
    ax.axis('off')

    event_mask = (p.index >= pd.to_datetime(EVENT_START)) & (p.index <= pd.to_datetime(EVENT_END))
    event_total = float(p[event_mask].sum()) if event_mask.any() else np.nan
    event_max = float(p[event_mask].max()) if event_mask.any() else np.nan
    classification = classify_event(ranks)

    sval = dict(zip(spatial_df["metric"], spatial_df["value"]))

    rows = [
        ["METRIC", "VALUE", "NOTES"],
        ["Dataset coverage", f"{p.index[0].date()} to {p.index[-1].date()}", f"{len(p)} daily values"],
        ["Event period", f"{EVENT_START} to {EVENT_END}", ""],
        ["Event total (municipality mean, daily)", f"{event_total:.2f} mm", ""],
        ["Event maximum daily", f"{event_max:.2f} mm", ""],
        ["Classification", classification, "precipitation-only"],
        ["", "", ""],
        ["ETCCDI-like index", "2026 value", "Long-term mean"],
        ["Rx1day", f"{ann.loc[2026,'Rx1day']:.2f}" if 2026 in ann.index else "NA", f"{ann['Rx1day'].mean():.2f}"],
        ["Rx5day", f"{ann.loc[2026,'Rx5day']:.2f}" if 2026 in ann.index else "NA", f"{ann['Rx5day'].mean():.2f}"],
        ["R10mm", f"{ann.loc[2026,'R10mm']:.0f}" if 2026 in ann.index else "NA", f"{ann['R10mm'].mean():.2f}"],
        ["R20mm", f"{ann.loc[2026,'R20mm']:.0f}" if 2026 in ann.index else "NA", f"{ann['R20mm'].mean():.2f}"],
        ["CDD", f"{ann.loc[2026,'CDD']:.0f}" if 2026 in ann.index else "NA", f"{ann['CDD'].mean():.2f}"],
        ["CWD", f"{ann.loc[2026,'CWD']:.0f}" if 2026 in ann.index else "NA", f"{ann['CWD'].mean():.2f}"],
        ["PRCPTOT", f"{ann.loc[2026,'PRCPTOT']:.2f}" if 2026 in ann.index else "NA", f"{ann['PRCPTOT'].mean():.2f}"],
        ["SDII", f"{ann.loc[2026,'SDII']:.2f}" if 2026 in ann.index else "NA", f"{ann['SDII'].mean():.2f}"],
        ["", "", ""],
        ["Main spatial index", "Value", "Unit"],
        ["Event accumulation mean", f"{sval.get('Event accumulation mean (mm)', np.nan):.2f}", "mm"],
        ["Event accumulation max", f"{sval.get('Event accumulation max (mm)', np.nan):.2f}", "mm"],
        ["Anomaly mean", f"{sval.get('Anomaly mean (mm)', np.nan):.2f}", "mm"],
        ["Anomaly max", f"{sval.get('Anomaly max (mm)', np.nan):.2f}", "mm"],
        ["Z-score max", f"{sval.get('Z-score max', np.nan):.2f}", "-"],
        ["Percentile mean", f"{sval.get('Percentile mean', np.nan):.2f}", "%"],
        ["Area ≥ 95th percentile", f"{sval.get('Area with percentile >= 95 (%)', np.nan):.2f}", "%"],
        ["Area ≥ 99th percentile", f"{sval.get('Area with percentile >= 99 (%)', np.nan):.2f}", "%"],
    ]

    table = ax.table(cellText=rows, cellLoc='left', loc='center', colWidths=[0.36, 0.26, 0.38])
    table.auto_set_font_size(False)
    table.set_fontsize(9)
    table.scale(1, 1.75)

    for i in range(3):
        table[(0, i)].set_facecolor(COLORS["primary"])
        table[(0, i)].set_text_props(weight='bold', color='white')

    for ridx in [7, 17]:
        for c in range(3):
            table[(ridx, c)].set_facecolor("#e9f2fb")
            table[(ridx, c)].set_text_props(weight='bold')

    plt.title("Juiz de Fora Municipality — Summary Table", fontsize=13, fontweight="bold", pad=20)
    plt.savefig(out_path, dpi=dpi, bbox_inches="tight", facecolor='white')
    plt.show()
    plt.close()
    print(f"✅ Summary table saved: {out_path}")

