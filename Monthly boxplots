def chirps_daily_fc(start, end):
    ic = ee.ImageCollection(CHIRPS_ID).filterDate(start, end).select(["precipitation"])
    scale = 5500

    def img_to_feat(img):
        stat = img.reduceRegion(
            reducer=ee.Reducer.mean(),
            geometry=roi_geom,
            scale=scale,
            bestEffort=True,
            maxPixels=1e13
        )
        d = ee.Date(img.get("system:time_start")).format("YYYY-MM-dd")
        return ee.Feature(None, {"date": d, "precip_mm": stat.get("precipitation")})

    return ee.FeatureCollection(ic.map(img_to_feat))

def fetch_chirps_year_to_csv(year, chirps_last_date):
    start = pd.Timestamp(year=year, month=1, day=1)
    end = pd.Timestamp(year=year + 1, month=1, day=1)

    chirps_last_date = pd.to_datetime(chirps_last_date)
    if start > chirps_last_date:
        return None

    end = min(end, chirps_last_date + pd.Timedelta(days=1))

    prefix = f"JDF_MUNIC_CHIRPS_daily_mean_{CACHE_TAG}_{year}"
    expected = os.path.join(OUT_DIR, f"{prefix}.csv")

    if os.path.exists(expected) and os.path.getsize(expected) > 0:
        print(f"✅ CHIRPS {year} cache hit:", expected)
        return expected

    alt = find_latest_matching(OUT_DIR, prefix)
    if alt and os.path.getsize(alt) > 0:
        print(f"✅ CHIRPS {year} using existing file:", alt)
        return alt

    print(f"⏳ Fetching CHIRPS {year}: {start.date()} → {(end - pd.Timedelta(days=1)).date()}")
    fc = chirps_daily_fc(start.strftime("%Y-%m-%d"), end.strftime("%Y-%m-%d"))
    info = fc.getInfo()
    feats = info.get("features", [])

    rows = []
    for ft in feats:
        props = ft.get("properties", {})
        rows.append({
            "date": props.get("date"),
            "precip_mm": props.get("precip_mm")
        })

    df = pd.DataFrame(rows)
    if df.empty:
        df = pd.DataFrame(columns=["date", "precip_mm"])

    df.to_csv(expected, index=False)
    print(f"✅ Saved CHIRPS year CSV: {expected} | n={len(df)}")
    return expected

