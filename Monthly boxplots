    im4 = axes[3].imshow(arr_z, extent=ext_z, origin="upper", cmap="RdBu_r", norm=norm_z)
    gdf_roi.boundary.plot(ax=axes[3], color="black", linewidth=1.2)
    axes[3].set_title("D) Z-score", fontweight="bold", loc="left")
    plt.colorbar(im4, ax=axes[3], fraction=0.046, pad=0.04)

    im5 = axes[4].imshow(arr_pct, extent=ext_pct, origin="upper", cmap="viridis", vmin=0, vmax=100)
