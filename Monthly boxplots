def find_latest_matching(out_dir: str, prefix: str):
    files = glob.glob(os.path.join(out_dir, f"{prefix}*.csv"))
    if not files:
        return None
    files = sorted(files, key=lambda p: os.path.getmtime(p), reverse=True)
    return files[0]

def load_precip_csv(path):
    df = pd.read_csv(path)
    if "date" not in df.columns or "precip_mm" not in df.columns:
        raise ValueError(f"CSV inválido: {path} | colunas={df.columns.tolist()}")
    df["date"] = pd.to_datetime(df["date"], errors="coerce")
    df["precip_mm"] = pd.to_numeric(df["precip_mm"], errors="coerce")
    df = df.dropna(subset=["date"]).sort_values("date").drop_duplicates("date")
    return df[["date", "precip_mm"]]

def read_clip_raster(path, clip_gdf):
    with rasterio.open(path) as src:
        out_image, out_transform = mask(src, clip_gdf.geometry, crop=True, nodata=np.nan)
        arr = out_image[0].astype(float)
        arr[arr <= -9999] = np.nan
        extent = plotting_extent(out_image[0], out_transform)
    return arr, extent

def finite_stats(arr):
    x = np.asarray(arr, dtype=float)
    x = x[np.isfinite(x)]
    if x.size == 0:
        return {
            "mean": np.nan, "median": np.nan, "std": np.nan, "min": np.nan,
            "max": np.nan, "p90": np.nan, "p95": np.nan, "p99": np.nan,
            "cv_pct": np.nan
        }
    mean = float(np.nanmean(x))
    std = float(np.nanstd(x))
    return {
        "mean": mean,
        "median": float(np.nanmedian(x)),
        "std": std,
        "min": float(np.nanmin(x)),
        "max": float(np.nanmax(x)),
        "p90": float(np.nanpercentile(x, 90)),
        "p95": float(np.nanpercentile(x, 95)),
        "p99": float(np.nanpercentile(x, 99)),
        "cv_pct": float((std / mean) * 100.0) if np.isfinite(mean) and mean != 0 else np.nan,
    }

def frac_ge(arr, thr):
    x = np.asarray(arr, dtype=float)
    valid = np.isfinite(x)
    if valid.sum() == 0:
        return np.nan
    return float((x[valid] >= thr).sum() / valid.sum() * 100.0)

def frac_gt(arr, thr):
    x = np.asarray(arr, dtype=float)
    valid = np.isfinite(x)
    if valid.sum() == 0:
        return np.nan
    return float((x[valid] > thr).sum() / valid.sum() * 100.0)

