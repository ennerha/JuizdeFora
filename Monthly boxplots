def imerg_event_total_image(event_start, event_end):
    ic0 = ee.ImageCollection(IMERG_ID).filterDate(
        event_start, (pd.to_datetime(event_end) + pd.Timedelta(days=1)).strftime("%Y-%m-%d")
    )
    band = detect_imerg_rate_band(ic0)
    ic = ic0.select([band])

    def rate_to_mm_step(img):
        t0 = ee.Date(img.get("system:time_start"))
        has_end = img.propertyNames().contains("system:time_end")
        t1 = ee.Date(ee.Algorithms.If(has_end, img.get("system:time_end"), t0.advance(30, "minute")))
        dur_hr = t1.difference(t0, "hour")
        dur_hr = ee.Number(ee.Algorithms.If(dur_hr.lte(0), 0.5, dur_hr))
        return img.multiply(dur_hr).rename("event_mm")

    return ic.map(rate_to_mm_step).sum().rename("event_mm").clip(roi_geom)

def chirps_baseline_eventwindow_ic(event_start, event_end, baseline_start, baseline_end):
    event_start = pd.to_datetime(event_start)
    event_end   = pd.to_datetime(event_end)
    month0, day0 = event_start.month, event_start.day
    month1, day1 = event_end.month, event_end.day

    start_year = pd.to_datetime(baseline_start).year
    end_year   = pd.to_datetime(baseline_end).year

    imgs = []
    for y in range(start_year, end_year + 1):
        s = pd.Timestamp(year=y, month=month0, day=day0).strftime("%Y-%m-%d")
        e = (pd.Timestamp(year=y, month=month1, day=day1) + pd.Timedelta(days=1)).strftime("%Y-%m-%d")
        img = ee.ImageCollection(CHIRPS_ID).filterDate(s, e).select("precipitation").sum().rename("clim_mm")
        imgs.append(img)

    return ee.ImageCollection(imgs)

def build_spatial_products():
    event_img = imerg_event_total_image(EVENT_START, EVENT_END)
    clim_ic = chirps_baseline_eventwindow_ic(EVENT_START, EVENT_END, BASELINE_START, BASELINE_END)

    clim_mean = clim_ic.mean().rename("clim_mean")
    clim_std  = clim_ic.reduce(ee.Reducer.stdDev()).rename("clim_std")

    chirps_ref = ee.ImageCollection(CHIRPS_ID).first().select("precipitation")
    event_on_chirps = event_img.resample("bilinear").reproject(chirps_ref.projection()).rename("event_mm")

    anomaly = event_on_chirps.subtract(clim_mean).rename("anomaly")
    zscore  = anomaly.divide(clim_std).rename("zscore").updateMask(clim_std.gt(0))

    n = ee.Number(clim_ic.size())
    percentile = clim_ic.map(lambda img: img.lte(event_on_chirps).rename("le")).sum() \
                        .divide(n).multiply(100).rename("percentile")

    return {
        "event": event_on_chirps.clip(roi_geom),
        "clim_mean": clim_mean.clip(roi_geom),
        "anomaly": anomaly.clip(roi_geom),
        "zscore": zscore.clip(roi_geom),
        "percentile": percentile.clip(roi_geom)
    }

def export_spatial_rasters():
    if all(os.path.exists(p) and os.path.getsize(p) > 0 for p in [
        RASTER_EVENT_TIF, RASTER_CLIM_MEAN_TIF, RASTER_ANOM_TIF, RASTER_ZSCORE_TIF, RASTER_PERCENTILE_TIF
    ]):
        print("✅ Cache hit: Spatial rasters already exist.")
        return

    imgs = build_spatial_products()

    geemap.ee_export_image(imgs["event"], filename=RASTER_EVENT_TIF, scale=5500, region=roi_geom.bounds(), file_per_band=False)
    geemap.ee_export_image(imgs["clim_mean"], filename=RASTER_CLIM_MEAN_TIF, scale=5500, region=roi_geom.bounds(), file_per_band=False)
    geemap.ee_export_image(imgs["anomaly"], filename=RASTER_ANOM_TIF, scale=5500, region=roi_geom.bounds(), file_per_band=False)
    geemap.ee_export_image(imgs["zscore"], filename=RASTER_ZSCORE_TIF, scale=5500, region=roi_geom.bounds(), file_per_band=False)
    geemap.ee_export_image(imgs["percentile"], filename=RASTER_PERCENTILE_TIF, scale=5500, region=roi_geom.bounds(), file_per_band=False)

    print("✅ Spatial rasters exported.")

