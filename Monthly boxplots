        ["Z-score mean", st_z["mean"]],
        ["Z-score max", st_z["max"]],
        ["Area with z-score >= 1 (%)", frac_ge(arr_z, 1)],
        ["Area with z-score >= 2 (%)", frac_ge(arr_z, 2)],
        ["Area with z-score >= 3 (%)", frac_ge(arr_z, 3)],
        ["Percentile mean", st_pct["mean"]],
        ["Percentile min", st_pct["min"]],
