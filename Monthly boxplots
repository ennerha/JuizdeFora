def detect_imerg_rate_band(ic):
    bnames = ic.first().bandNames().getInfo()
    candidates = ["precipitation", "precipitationCal", "HQprecipitation", "precipitationUncal"]
    for b in candidates:
        if b in bnames:
            return b
    raise ValueError(f"IMERG precipitation band not found. Bands: {bnames}")

def imerg_daily_fc(start, end):
    ic0 = ee.ImageCollection(IMERG_ID).filterDate(start, end)
    band = detect_imerg_rate_band(ic0)
    ic = ic0.select([band])

    def rate_to_mm_step(img):
        t0 = ee.Date(img.get("system:time_start"))
        has_end = img.propertyNames().contains("system:time_end")
        t1 = ee.Date(ee.Algorithms.If(has_end, img.get("system:time_end"), t0.advance(30, "minute")))
        dur_hr = t1.difference(t0, "hour")
        dur_hr = ee.Number(ee.Algorithms.If(dur_hr.lte(0), 0.5, dur_hr))
        return img.multiply(dur_hr).copyProperties(img, img.propertyNames())

    ic_mm = ic.map(rate_to_mm_step)

    start_d = ee.Date(start)
    end_d   = ee.Date(end)
    n_days = end_d.difference(start_d, "day").toInt()

    def day_to_feat(k):
        d0 = start_d.advance(k, "day")
        d1 = d0.advance(1, "day")
        day_ic = ic_mm.filterDate(d0, d1)
        count = day_ic.size()
        day_sum = day_ic.sum()

        stat = ee.Dictionary(
            ee.Algorithms.If(
                count.gt(0),
                day_sum.reduceRegion(
                    reducer=ee.Reducer.mean(),
                    geometry=roi_geom,
                    scale=10000,
                    bestEffort=True,
                    maxPixels=1e13
                ),
                ee.Dictionary({})
            )
        )

        dstr = d0.format("YYYY-MM-dd")
        precip_val = stat.get(band)
        return ee.Feature(None, {"date": dstr, "precip_mm": precip_val, "count": count})

    return ee.FeatureCollection(ee.List.sequence(0, n_days.subtract(1)).map(day_to_feat))

def month_start_end(year, month, last_available):
    start = pd.Timestamp(year=year, month=month, day=1)
    last_day = calendar.monthrange(year, month)[1]
    end = pd.Timestamp(year=year, month=month, day=last_day) + pd.Timedelta(days=1)

    last_available = pd.to_datetime(last_available)
    if start > last_available:
        return None, None

    end = min(end, last_available + pd.Timedelta(days=1))
    return start.strftime("%Y-%m-%d"), end.strftime("%Y-%m-%d")

